    // --- FEATURED VIDEO ---
    const featuredVideoId = "oqU41QwtAGE";

    // --- 1. GENERATE LOVE PATTERN ---
    function generateLovePattern() {
      const container = document.getElementById('lovePattern');
      container.innerHTML = '';
      const positions = [
        { top: '10%', left: '5%', rotate: -12 },
        { top: '25%', right: '8%', rotate: 8 },
        { top: '50%', left: '12%', rotate: -8 },
        { top: '65%', right: '5%', rotate: 12 },
        { top: '80%', left: '8%', rotate: -15 },
        { bottom: '5%', right: '15%', rotate: 6 },
      ];
      positions.forEach((pos, i) => {
        const el = document.createElement('div');
        el.className = 'love-text';
        el.textContent = '#hacktheplanet';
        Object.keys(pos).forEach(key => {
          if (key !== 'rotate') el.style[key] = pos[key];
        });
        el.style.opacity = 0.02 + (i % 3) * 0.015;
        el.style.transform = `rotate(${pos.rotate}deg)`;
        container.appendChild(el);
      });
    }
    generateLovePattern();

    // --- 2. VIDEO PLACEHOLDER → IFRAME LAZY LOAD ---
    const videoPlaceholder = document.getElementById('videoPlaceholder');
    const videoIframe = document.getElementById('videoIframe');

    videoPlaceholder.addEventListener('click', function () {
      videoIframe.src = `https://www.youtube.com/embed/${featuredVideoId}?autoplay=1&rel=0`;
      this.style.display = 'none';
    });

    // --- 3. GENERATE UI ---
    const contentArea = document.getElementById('contentArea');

    function createLinkItemInner(item) {
      const imgContent = item.img
        ? `<img src="${item.img}" alt="${item.name}" loading="lazy">`
        : `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
             <path d="M19 3H5a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2V5a2 2 0 00-2-2z"/>
             <circle cx="8.5" cy="8.5" r="1.5"/>
             <path d="M21 15l-5-5L5 21"/>
           </svg>`;

      const tagClass = item.tagClass || 'tag-default';
      const tagHtml = item.tag ? `<span class="link-tag ${tagClass}">${item.tag}</span>` : '';

      return `
        <div class="link-img">${imgContent}</div>
        <div class="link-content">
          <div class="link-name">${item.name}</div>
          <div class="link-desc">${item.desc}</div>
        </div>
        ${tagHtml}
        <svg class="link-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M9 18l6-6-6-6"/>
        </svg>
      `;
    }

    function generateUI() {
      contentArea.innerHTML = '';

      collectionData.forEach(section => {
        const sectionEl = document.createElement('div');
        sectionEl.className = 'section';

        const visibleItems = section.items.slice(0, 3);
        const hiddenItems = section.items.slice(3);
        const hasMore = hiddenItems.length > 0;

        let itemsHtml = visibleItems.map(item =>
          `<a href="${item.url}" class="link-item">${createLinkItemInner(item)}</a>`
        ).join('');

        if (hasMore) {
          const hiddenItemsHtml = hiddenItems.map(item =>
            `<a href="${item.url}" class="link-item hidden-item" style="display: none;">
              ${createLinkItemInner(item)}
            </a>`
          ).join('');
          itemsHtml += hiddenItemsHtml;
        }

        sectionEl.innerHTML = `
          <div class="section-header">
            <div class="section-title">${section.title}</div>
            <div class="section-count">${section.items.length} resources</div>
          </div>
          <div class="links-list">
            ${itemsHtml}
            ${hasMore ? `<button class="show-more-btn" onclick="toggleItems(this)">Show ${hiddenItems.length} more</button>` : ''}
          </div>
        `;

        contentArea.appendChild(sectionEl);
      });
    }

    function toggleItems(btn) {
      const section = btn.parentElement;
      const hiddenItems = section.querySelectorAll('.hidden-item');
      const isVisible = hiddenItems[0] && hiddenItems[0].style.display !== 'none';

      hiddenItems.forEach(item => {
        item.style.display = isVisible ? 'none' : 'flex';
      });

      btn.textContent = isVisible
        ? `Show ${hiddenItems.length} more`
        : 'Show less';
    }

    generateUI();
  </script>
